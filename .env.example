# .env.example – copy to .env and fill in your keys
# -------------------------------------------------------

# --- LLM Configuration ---
PLANNER_MODEL=gpt-4o-mini
SYNTHESIZER_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini
JUDGE_THRESHOLD=0.75
HISTORY_WINDOW=3          # number of past turns sent to the planner (default: 3)

# --- API Keys ---
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=your_anthropic_key   # (futuro: soporte Claude)

# LangSmith tracing (optional but recommended)
# Sign up at https://smith.langchain.com → Settings → API keys
LANGCHAIN_TRACING_V2=false # Set to true to enable LangSmith tracing
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=decision-intelligence-agent

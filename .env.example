# .env.example – copy to .env and fill in your keys
# -------------------------------------------------------

# --- LLM Configuration ---
# Primary provider per node: "openai" (default) or "anthropic"
PLANNER_PROVIDER=openai
PLANNER_MODEL=gpt-4o-mini
SYNTHESIZER_PROVIDER=openai
SYNTHESIZER_MODEL=gpt-4o-mini
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o-mini
JUDGE_THRESHOLD=0.75
HISTORY_WINDOW=3          # number of past turns sent to the planner (default: 3)

# --- Fallback provider (12.4) ---
# Used automatically when the primary provider fails (any node).
# Leave blank to disable fallback.
FALLBACK_PROVIDER=anthropic
FALLBACK_MODEL=claude-haiku-4-5-20251001

# --- Rate-limit / retry settings (12.5) ---
LLM_MAX_RETRIES=2         # max retries on 429 before switching to fallback
LLM_TIMEOUT=30            # per-call timeout in seconds

# --- Database (optional — leave unset to use SQLite + FAISS for local dev) ---
# Start with: docker compose up -d
DATABASE_URL=postgresql://llull:llull@localhost:5432/llull

# --- API Keys ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...  # required when FALLBACK_PROVIDER=anthropic (or primary)

# --- FastAPI / CORS ---
CORS_ORIGINS=http://localhost:8501,http://localhost:3000,http://localhost:8000

# --- LLM Budget ceilings (item 8.7.b) — 0 = no limit ---
RUN_MAX_LLM_CALLS=20          # max LLM calls per agent run
RUN_MAX_WALLCLOCK_S=60        # max wall-clock seconds per run
RUN_MAX_COST_USD=1.0          # max spend in USD per run
RUN_MAX_TOKENS=50000          # max total tokens (input + output) per run

# --- Currency (item 8.7.a) ---
EUR_USD_RATE=                 # override Frankfurter API rate; leave blank to fetch live

# LangSmith tracing (optional but recommended)
# Sign up at https://smith.langchain.com → Settings → API keys
LANGCHAIN_TRACING_V2=false # Set to true to enable LangSmith tracing
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=decision-intelligence-agent
